# Система кэширования для улучшения производительности
class PerformanceCache:
    """Класс для кэширования данных и улучшения производительности"""
    
    def __init__(self):
        self.cache = {}
        self.cache_timestamps = {}
        self.cache_lock = threading.RLock()
        self.request_stats = defaultdict(int)
        self.response_times = defaultdict(list)
        self.max_cache_size = 1000
        self.cache_ttl = 300  # 5 минут
        
    def get(self, key):
        """Получить значение из кэша"""
        with self.cache_lock:
            if key in self.cache:
                # Проверяем TTL
                if time.time() - self.cache_timestamps[key] < self.cache_ttl:
                    return self.cache[key]
                else:
                    # Удаляем устаревшие данные
                    del self.cache[key]
                    del self.cache_timestamps[key]
            return None
    
    def set(self, key, value):
        """Установить значение в кэш"""
        with self.cache_lock:
            # Очищаем кэш если он переполнен
            if len(self.cache) >= self.max_cache_size:
                self._evict_oldest()
            
            self.cache[key] = value
            self.cache_timestamps[key] = time.time()
    
    def _evict_oldest(self):
        """Удалить самые старые записи из кэша"""
        if not self.cache_timestamps:
            return
            
        # Удаляем 20% самых старых записей
        sorted_keys = sorted(self.cache_timestamps.items(), key=lambda x: x[1])
        evict_count = max(1, len(sorted_keys) // 5)
        
        for key, _ in sorted_keys[:evict_count]:
            del self.cache[key]
            del self.cache_timestamps[key]
    
    def clear(self):
        """Очистить весь кэш"""
        with self.cache_lock:
            self.cache.clear()
            self.cache_timestamps.clear()
    
    def record_request(self, endpoint, response_time):
        """Записать статистику запроса"""
        self.request_stats[endpoint] += 1
        self.response_times[endpoint].append(response_time)
        
        # Ограничиваем размер списка времени ответа
        if len(self.response_times[endpoint]) > 100:
            self.response_times[endpoint] = self.response_times[endpoint][-50:]
    
    def get_stats(self):
        """Получить статистику производительности"""
        stats = {}
        for endpoint, times in self.response_times.items():
            if times:
                stats[endpoint] = {
                    'requests': self.request_stats[endpoint],
                    'avg_time': sum(times) / len(times),
                    'min_time': min(times),
                    'max_time': max(times)
                }
        return stats


def update_request_status(req_id, new_status):

    """Обновляет статус заявки в requests.txt и requests.csv"""

    updated = False

    # Обновляем в текстовом файле

    if os.path.exists('requests.txt'):

        with open('requests.txt', 'r', encoding='utf-8') as f:

            lines = f.readlines()

        with open('requests.txt', 'w', encoding='utf-8') as f:

            i = 0

            while i < len(lines):

                if req_id in lines[i]:

                    # Найдено начало заявки

                    while i < len(lines) and not lines[i].startswith('Статус:'):

                        f.write(lines[i])

                        i += 1

                    if i < len(lines) and lines[i].startswith('Статус:'):

                        f.write(f'Статус: {new_status}\n')

                        updated = True

                        i += 1

                    else:

                        f.write(f'Статус: {new_status}\n')

                    # Копируем до разделителя

                    while i < len(lines) and not lines[i].startswith('='):

                        f.write(lines[i])

                        i += 1

                else:

                    f.write(lines[i])

                    i += 1

    # Обновляем в CSV

    if os.path.exists('requests.csv'):

        with open('requests.csv', 'r', encoding='utf-8') as f:

            rows = list(csv.reader(f))

        with open('requests.csv', 'w', encoding='utf-8', newline='') as f:

            writer = csv.writer(f)

            for row in rows:

                if row and row[0] == req_id:

                    row[1] = new_status

                    updated = True

                writer.writerow(row)

    return updated



def notify_user_about_status(req_id, new_status):

    """Уведомляет пользователя о смене статуса заявки"""

    if os.path.exists('requests.txt'):

        with open('requests.txt', 'r', encoding='utf-8') as f:

            lines = f.readlines()

        user_id = None

        found = False

        req = []

        for line in lines:

            if req_id in line:

                found = True

                req = [line]

            elif found and line.startswith('Пользователь:'):

                # Извлекаем ID пользователя (если есть)

                if '@' in line:

                    # username

                    user_id = line.split('@',1)[1].strip()

                else:

                    # возможно, имя или id

                    user_id = line.split(':',1)[1].strip()

                break

            elif found:

                req.append(line)

        if user_id:

            # Пробуем отправить уведомление (по username или id)

            try:

                msg = f'🔔 Статус вашей заявки {req_id} изменён на: {new_status}'

                # Если user_id — это число, значит id

                if user_id.isdigit():

                    bot.send_message(int(user_id), msg)

                else:

                    bot.send_message(f'@{user_id}', msg)

            except Exception as e:


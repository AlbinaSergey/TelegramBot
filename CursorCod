    """Обрабатывает повтор заявки по кнопке"""

    req_id = call.data.split('_',1)[1]

    # Найти заявку по req_id

    if os.path.exists('requests.txt'):

        with open('requests.txt', 'r', encoding='utf-8') as f:

            lines = f.readlines()

        req = []

        found = False

        for line in lines:

            if req_id in line:

                found = True

                req = [line]

            elif found and line.startswith('✉️'):

                break

            elif found:

                req.append(line)

        # Парсим поля

        data = {}

        for l in req:

            if l.startswith('Тип:'):

                data['type'] = l.split(':',1)[1].strip()

            elif l.startswith('Картридж:'):

                data['cartridge'] = l.split(':',1)[1].strip()

            elif l.startswith('Количество:'):

                data['quantity'] = l.split(':',1)[1].strip()

            elif l.startswith('Оборудование:'):

                data['equipment'] = l.split(':',1)[1].strip()

            elif l.startswith('Проблема:'):

                data['problem'] = l.split(':',1)[1].strip()

            elif l.startswith('Подразделение:'):

                data['branch'] = l.split(':',1)[1].strip()

        # Запускаем новый флоу с этими данными

        chat_id = call.message.chat.id

        user_data[chat_id] = {}

        if data.get('type') == '📦 Заказ картриджей':

            user_data[chat_id]['type'] = data['type']

            user_data[chat_id]['cartridge'] = data.get('cartridge','')

            user_data[chat_id]['quantity'] = data.get('quantity','')

            start_flow(chat_id)

            if data.get('cartridge'):

                ask_cartridge_inline(chat_id)

            if data.get('quantity'):

                ask_quantity_inline(chat_id)

        elif data.get('type') == '🔧 Ремонт оборудования':

            user_data[chat_id]['type'] = data['type']

            user_data[chat_id]['equipment'] = data.get('equipment','')

            user_data[chat_id]['problem'] = data.get('problem','')

            start_flow(chat_id)

            if data.get('equipment'):

                ask_equipment_inline(chat_id)

            if data.get('problem'):

                ask_problem_inline(chat_id)

        # Если есть branch, сразу финализируем

        if data.get('branch'):

            user_data[chat_id]['branch'] = data['branch']

            finalize_request(chat_id)

        bot.answer_callback_query(call.id, 'Данные заявки скопированы! Можете изменить нужные поля.')



@bot.message_handler(func=lambda m: True)

def main_handler(m):

    """Универсальный обработчик всех сообщений"""

    chat_id = m.chat.id

    text = m.text

    

    # Обработка административных команд

    if chat_id == ADMIN_ID:

        if text == "📊 Статистика":

            cmd_stats(m)

            return

        elif text == "👥 Активные пользователи":

            cmd_users(m)

            return

        elif text == "🔄 Сбросить счетчик":

            cmd_reset(m)

            return

        elif text == "📋 Последние заявки":

            cmd_requests(m)

            return

        elif text == "💾 Резервная копия":

            cmd_backup(m)

            return

        elif text == "📝 Логи":

            cmd_logs(m)

            return

        elif text == "🧹 Очистить данные":

            cmd_clear(m)

            return

        elif text == "❌ Закрыть меню":

            markup = types.ReplyKeyboardRemove()

            bot.send_message(chat_id, "🔧 Меню администратора закрыто", reply_markup=markup)

            return

        elif text == "📤 Экспорт заявок":

            export_format_markup = types.ReplyKeyboardMarkup(resize_keyboard=True, row_width=2)

            export_format_markup.add("Excel (.xlsx)", "CSV (.csv)")

            export_format_markup.add("❌ Отмена")

            bot.send_message(chat_id, "Выберите формат экспорта:", reply_markup=export_format_markup)

            user_data[chat_id]["step"] = "export_format"

            return

        elif text == "📥 Экспорт в Excel":

            cmd_export_excel(m)

            start_flow(chat_id)

            return

        elif text == "📝 Изменить статус":

            bot.send_message(chat_id, 'Используйте команду: /setstatus REQ-0001 done')

            return

    

    # Обработка отмены

    if text == "❌ Отмена":

        start_flow(chat_id)

        return

    

    # Если пользователь не в процессе создания заявки

    if chat_id not in user_data or "step" not in user_data[chat_id]:

        start_flow(chat_id)

        return

    

    step = user_data[chat_id]["step"]

    

    # Обработка в зависимости от текущего шага

    if step == "start":

        if text == "📦 Заказ картриджей":

            user_data[chat_id]["type"] = text

            ask_cartridge_inline(chat_id)

        elif text == "🔧 Ремонт оборудования":

            user_data[chat_id]["type"] = text

            ask_equipment_inline(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите тип заявки кнопкой.")

            show_type_selection(chat_id, include_welcome=False)

    

    elif step == "cartridge":

        if text in CARTRIDGES:

            user_data[chat_id]["cartridge"] = text

            ask_quantity_inline(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите картридж кнопкой.")

            ask_cartridge_inline(chat_id)

    

    elif step == "quantity":

        if text in QUANTITIES:

            user_data[chat_id]["quantity"] = text

            ask_city_inline(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите количество кнопкой.")

            ask_quantity_inline(chat_id)

    

    elif step == "equipment":

        if text in EQUIP_PROBLEMS:

            user_data[chat_id]["equipment"] = text

            ask_problem_inline(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите оборудование кнопкой.")

            ask_equipment_inline(chat_id)

    

    elif step == "problem":

        if text == "Другая проблема":

            ask_custom_problem_inline(chat_id)

        elif text in EQUIP_PROBLEMS.get(user_data[chat_id]['equipment'], []):

            user_data[chat_id]["problem"] = text

            ask_city_inline(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите проблему кнопкой.")

            ask_problem_inline(chat_id)

    

    elif step == "custom_problem":

        user_data[chat_id]["problem"] = text

        ask_city_inline(chat_id)

    

    elif step == "city":

        if text in CITIES:

            if CITIES[text]:  # Если есть подразделения

                user_data[chat_id]["city"] = text

                ask_subbranch(chat_id, text)

            else:  # Если нет подразделений

                user_data[chat_id]["branch"] = text

                finalize_request(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите город кнопкой.")

            ask_city_inline(chat_id)

    

    elif step == "subbranch":

        if text in sum(CITIES.values(), []):

            user_data[chat_id]["branch"] = text

            finalize_request(chat_id)

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите подразделение кнопкой.")

            ask_subbranch(chat_id, user_data[chat_id]["city"])

    

    elif step == "export_format":

        if text == "Excel (.xlsx)":

            cmd_export_excel(m)

            start_flow(chat_id)

            return

        elif text == "CSV (.csv)":

            cmd_export(m)

            start_flow(chat_id)

            return

        else:

            bot.send_message(chat_id, "Пожалуйста, выберите формат кнопкой.")

            return

    

    else:

        # Неизвестный шаг - начинаем заново

        bot.send_message(chat_id, "Произошла ошибка. Начинаем заново.")

        start_flow(chat_id)



def run_bot():

    """Основная функция запуска бота"""

    global bot_running

    bot_running = True

    print("🟢 Бот запущен")

    logging.info("Бот запущен")

    

    try:

        bot.infinity_polling(timeout=60, long_polling_timeout=30, logger_level=logging.INFO)

    except KeyboardInterrupt:

        bot_running = False

        print("🔴 Бот остановлен пользователем")

        logging.info("Бот остановлен пользователем")

    except Exception as e:

        bot_running = False

        print(f"❗ Ошибка polling: {e}")

        logging.error(f"Ошибка polling: {e}")

    finally:

        bot_running = False

        print("ℹ️ Бот завершил работу")

        logging.info("Бот завершил работу")



if __name__ == '__main__':

    run_bot() 

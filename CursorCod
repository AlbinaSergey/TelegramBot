# Декораторы для обработки ошибок
def error_handler(func):
    """Декоратор для обработки ошибок в функциях бота"""
    @functools.wraps(func)
    def wrapper(*args, **kwargs):
        try:
            return func(*args, **kwargs)
        except Exception as e:
            error_msg = f"Ошибка в функции {func.__name__}: {str(e)}"
            logging.error(f"{error_msg}\n{traceback.format_exc()}")
            
            # Пытаемся найти chat_id для отправки уведомления пользователю
            chat_id = None
            if args:
                if hasattr(args[0], 'chat'):
                    chat_id = args[0].chat.id
                elif hasattr(args[0], 'message'):
                    chat_id = args[0].message.chat.id
                elif isinstance(args[0], (int, str)):
                    try:
                        chat_id = int(args[0])
                    except (ValueError, TypeError):
                        pass
            
            if chat_id:
                try:
                    bot.send_message(chat_id, "❌ Произошла ошибка. Попробуйте еще раз или обратитесь к администратору.")
                except Exception as send_error:
                    logging.error(f"Не удалось отправить сообщение об ошибке: {send_error}")
            
            return None
    return wrapper

def safe_bot_operation(operation_name="Операция"):
    """Декоратор для безопасных операций с Telegram API"""
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            try:
                return func(*args, **kwargs)
            except telebot.apihelper.ApiTelegramException as e:
                logging.error(f"Telegram API ошибка в {operation_name}: {e}")
                if e.error_code == 403:
                    logging.warning(f"Бот заблокирован пользователем или в чате")
                elif e.error_code == 429:
                    logging.warning(f"Превышен лимит запросов, ожидание...")
                    time.sleep(1)
                    return func(*args, **kwargs)  # Повторная попытка
                return None
            except Exception as e:
                logging.error(f"Неожиданная ошибка в {operation_name}: {e}\n{traceback.format_exc()}")
                return None
        return wrapper
    return decorator

def cache_result(ttl=300, key_func=None):
    """Декоратор для кэширования результатов функций"""
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            # Генерируем ключ кэша
            if key_func:
                cache_key = key_func(*args, **kwargs)
            else:
                cache_key = f"{func.__name__}_{hash(str(args))}{hash(str(kwargs))}"
            
            # Пытаемся получить из кэша
            cached_result = performance_cache.get(cache_key)
            if cached_result is not None:
                return cached_result
            
            # Выполняем функцию и кэшируем результат
            start_time = time.time()
            result = func(*args, **kwargs)
            end_time = time.time()
            
            # Записываем статистику
            performance_cache.record_request(func.__name__, end_time - start_time)
            
            # Кэшируем результат
            performance_cache.set(cache_key, result)
            
            return result
        return wrapper
    return decorator

def measure_performance(func):
    """Декоратор для измерения производительности функций"""
    @functools.wraps(func)
    def wrapper(*args, **kwargs):
        start_time = time.time()
        try:
            result = func(*args, **kwargs)
            return result
        finally:
            end_time = time.time()
            performance_cache.record_request(func.__name__, end_time - start_time)
    return wrapper

def async_operation(func):
    """Декоратор для выполнения операций в отдельном потоке"""
    @functools.wraps(func)
    def wrapper(*args, **kwargs):
        def run_async():
            try:
                return func(*args, **kwargs)
            except Exception as e:
                logging.error(f"Ошибка в асинхронной операции {func.__name__}: {e}")
                return None
        
        # Выполняем в thread pool если операция может быть долгой
        future = thread_pool.submit(run_async)
        return future.result(timeout=30)  # Таймаут 30 секунд
    return wrapper


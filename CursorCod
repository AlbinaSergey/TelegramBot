        elif line.startswith('Оборудование:'):

            data['Оборудование'] = line.split(':',1)[1].strip()

        elif line.startswith('Проблема:'):

            data['Проблема'] = line.split(':',1)[1].strip()

        elif line.startswith('Подразделение:'):

            data['Подразделение'] = line.split(':',1)[1].strip()

        elif line.startswith('Пользователь:'):

            data['Пользователь'] = line.split(':',1)[1].strip()

        elif line.startswith('🕒') or line.startswith('Дата:'):

            data['Дата'] = line.split(':',1)[1].strip() if ':' in line else line.strip()

        elif line.startswith('Город:'):

